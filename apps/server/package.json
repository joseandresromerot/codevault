{
  "name": "@codevault/server",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && prisma migrate deploy && tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/jwt": "^9.0.3",
    "@prisma/client": "^6.19.2",
    "@codevault/types": "workspace:*",
    "fastify": "^5.3.2",
    "mercurius": "^15.0.0",
    "graphql": "^16.10.0",
    "@pothos/core": "^4.3.0",
    "@pothos/plugin-prisma": "^4.5.0",
    "pino-pretty": "^13.1.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.13",
    "@vitest/coverage-v8": "^4.1.0",
    "prisma": "^6.19.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^4.1.0"
  }
}
